// ============================================================
// 領域實體模型模板 (DBML)
// ============================================================
// 階段: Phase 2 - 領域建模
// 目的: 定義領域實體、關係與約束
// 參考: https://www.dbml.org/
//
// 填寫指南:
// 1. 從 Event Storming 識別的聚合中提取實體
// 2. 定義實體的屬性與型別
// 3. 建立實體之間的關係
// 4. 設定索引與唯一性限制
// 5. 加入註解說明業務邏輯
//
// 注意: 每個 Table 應有對應的 haARM resource 定義
// 參見 phase2-access-control.haarm.yaml
// 對應規則: DBML Table 名稱 = haARM resource.id
// ============================================================

// ------------------------------------------------------------
// Project 設定
// ------------------------------------------------------------
Project project_name {
  database_type: 'PostgreSQL'  // PostgreSQL | MySQL | SQLite
  Note: '''
    # 專案名稱

    ## 描述
    [專案簡介]

    ## 版本
    v1.0 (YYYY-MM-DD)

    ## 負責人
    [姓名]
  '''
}

// ============================================================
// [領域 1: 如 User Management]
// ============================================================

// ------------------------------------------------------------
// Table: users (使用者)
// ------------------------------------------------------------
Table users {
  // 主鍵
  id uuid [primary key, default: `gen_random_uuid()`]

  // 基本資訊
  email varchar(255) [unique, not null, note: '使用者 Email (登入帳號)']
  username varchar(50) [unique, not null, note: '使用者名稱']
  password_hash varchar(255) [not null, note: 'bcrypt 雜湊後的密碼']

  // 個人資訊
  first_name varchar(50) [note: '名']
  last_name varchar(50) [note: '姓']
  phone varchar(20) [note: '電話號碼']
  avatar_url varchar(500) [note: '頭像圖片 URL']

  // 狀態與設定
  status varchar(20) [not null, default: 'active', note: '狀態: active | inactive | locked']
  email_verified boolean [default: false, note: 'Email 是否已驗證']
  phone_verified boolean [default: false, note: '電話是否已驗證']

  // 會員相關
  member_level varchar(20) [default: 'bronze', note: '會員等級: bronze | silver | gold | platinum']
  loyalty_points integer [default: 0, note: '忠誠點數']

  // 時間戳記
  created_at timestamp [not null, default: `now()`, note: '建立時間']
  updated_at timestamp [not null, default: `now()`, note: '最後更新時間']
  last_login_at timestamp [note: '最後登入時間']

  // 索引
  indexes {
    email [unique, name: 'idx_users_email']
    username [unique, name: 'idx_users_username']
    status [name: 'idx_users_status']
    (member_level, loyalty_points) [name: 'idx_users_member']
    created_at [name: 'idx_users_created_at']
  }

  Note: '''
    使用者主表

    業務規則:
    - Email 必須唯一且為有效格式
    - 密碼必須符合強度要求 (8 字元以上,包含英數字)
    - 帳號鎖定 (locked) 需由管理員手動解鎖
    - 會員等級每月 1 號根據近 12 個月消費自動更新
  '''
}

// ------------------------------------------------------------
// Table: user_sessions (使用者 Session)
// ------------------------------------------------------------
Table user_sessions {
  id uuid [primary key]
  user_id uuid [ref: > users.id, not null]
  token varchar(255) [unique, not null, note: 'Session Token']
  refresh_token varchar(255) [unique, note: 'Refresh Token']
  ip_address varchar(45) [note: 'IP 位址']
  user_agent text [note: 'User Agent']
  expires_at timestamp [not null, note: 'Token 過期時間']
  created_at timestamp [not null, default: `now()`]

  indexes {
    token [unique, name: 'idx_sessions_token']
    user_id [name: 'idx_sessions_user_id']
    expires_at [name: 'idx_sessions_expires']
  }

  Note: 'Session 管理表,用於追蹤使用者登入狀態'
}

// ============================================================
// [領域 2: 如 Product Catalog]
// ============================================================

// ------------------------------------------------------------
// Table: products (商品)
// ------------------------------------------------------------
Table products {
  id uuid [primary key]
  name varchar(200) [not null, note: '商品名稱']
  slug varchar(200) [unique, note: 'URL 友善的識別碼']
  description text [note: '商品描述']

  category_id uuid [ref: > categories.id, note: '分類 ID']
  brand varchar(100) [note: '品牌']

  // 狀態
  status varchar(20) [not null, default: 'draft', note: 'draft | active | inactive']

  // SEO
  meta_title varchar(200) [note: 'SEO 標題']
  meta_description text [note: 'SEO 描述']

  // 時間戳記
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  published_at timestamp [note: '上架時間']

  indexes {
    slug [unique]
    category_id
    status
    (status, published_at) [name: 'idx_products_active']
  }

  Note: '''
    商品主表

    業務規則:
    - 商品必須至少有一個變體 (variant) 才能上架
    - slug 自動從 name 產生,必須唯一
    - 上架 (active) 商品必須有庫存
  '''
}

// ------------------------------------------------------------
// Table: product_variants (商品變體)
// ------------------------------------------------------------
Table product_variants {
  id uuid [primary key]
  product_id uuid [ref: > products.id, not null, note: '商品 ID']
  sku varchar(50) [unique, not null, note: '庫存單位代碼 (唯一)']

  name varchar(100) [note: '變體名稱 (如: 紅色 / 128GB)']

  // 價格
  price decimal(10,2) [not null, note: '售價']
  compare_at_price decimal(10,2) [note: '原價 (用於顯示折扣)']
  cost decimal(10,2) [note: '成本']

  // 規格
  option1_name varchar(50) [note: '規格 1 名稱 (如: 顏色)']
  option1_value varchar(50) [note: '規格 1 值 (如: 紅色)']
  option2_name varchar(50) [note: '規格 2 名稱 (如: 容量)']
  option2_value varchar(50) [note: '規格 2 值 (如: 128GB)']
  option3_name varchar(50) [note: '規格 3 名稱']
  option3_value varchar(50) [note: '規格 3 值']

  // 其他
  image_url varchar(500) [note: '變體專屬圖片']
  weight decimal(10,2) [note: '重量 (kg)']

  created_at timestamp [not null, default: `now()`]

  indexes {
    sku [unique]
    product_id
  }

  Note: '''
    商品變體表

    業務規則:
    - SKU 必須唯一
    - 價格必須 > 0
    - compare_at_price 若有值,必須 >= price
  '''
}

// ------------------------------------------------------------
// Table: categories (分類)
// ------------------------------------------------------------
Table categories {
  id uuid [primary key]
  name varchar(100) [not null, note: '分類名稱']
  slug varchar(100) [unique, note: 'URL 識別碼']
  parent_id uuid [ref: > categories.id, note: '父分類 ID (支援多層分類)']

  description text
  image_url varchar(500)
  sort_order integer [default: 0, note: '排序順序']

  is_active boolean [default: true]

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    slug [unique]
    parent_id
    sort_order
  }

  Note: '''
    分類表 (支援多層結構)

    範例:
    - 電子產品 (parent_id: null)
      - 手機 (parent_id: 電子產品 ID)
        - iPhone (parent_id: 手機 ID)
  '''
}

// ============================================================
// [領域 3: 如 Inventory Management]
// ============================================================

Table inventory {
  id uuid [primary key]
  variant_id uuid [ref: > product_variants.id, not null]
  warehouse_id uuid [ref: > warehouses.id, not null]

  // 庫存數量
  quantity integer [not null, default: 0, note: '實際庫存']
  reserved_quantity integer [not null, default: 0, note: '預留庫存 (訂單建立時預留)']
  available_quantity integer [note: '可售庫存 (計算欄位: quantity - reserved_quantity)']

  // 安全庫存
  safety_stock integer [default: 0, note: '安全庫存 (警示門檻)']

  updated_at timestamp [not null, default: `now()`]

  indexes {
    (variant_id, warehouse_id) [unique, name: 'idx_inventory_variant_warehouse']
    available_quantity [name: 'idx_inventory_available']
  }

  Note: '''
    庫存表

    業務規則:
    - available_quantity = quantity - reserved_quantity
    - 可售庫存不可為負數
    - 當 available_quantity < safety_stock 時發送補貨通知
  '''
}

Table warehouses {
  id uuid [primary key]
  name varchar(100) [not null]
  code varchar(20) [unique, not null, note: '倉庫代碼']

  address varchar(200)
  city varchar(50)
  country varchar(50)

  is_active boolean [default: true]

  created_at timestamp [not null, default: `now()`]
}

// ============================================================
// [領域 4: 如 Order Management]
// ============================================================

// (依照類似格式繼續定義訂單、支付、物流等表...)

// ------------------------------------------------------------
// Enum 定義 (選填)
// ------------------------------------------------------------
Enum order_status {
  pending [note: '待付款']
  paid [note: '已付款']
  confirmed [note: '已確認']
  shipped [note: '已出貨']
  delivered [note: '已送達']
  cancelled [note: '已取消']
  refunded [note: '已退款']
}

Enum payment_method {
  credit_card [note: '信用卡']
  paypal [note: 'PayPal']
  bank_transfer [note: '銀行轉帳']
  cash_on_delivery [note: '貨到付款']
}

// ============================================================
// 關係圖說明
// ============================================================

// 一對多關係
// Ref: table1.column > table2.column  (一對多,table1 的一個記錄對應 table2 的多個記錄)

// 範例:
// - 一個 User 可以有多個 Orders
// - 一個 Category 可以有多個 Products
// - 一個 Product 可以有多個 Variants

// 多對多關係 (需要中間表)
// 範例: products 與 tags 多對多
Table products_tags {
  product_id uuid [ref: > products.id]
  tag_id uuid [ref: > tags.id]

  indexes {
    (product_id, tag_id) [pk]  // 複合主鍵
  }
}

Table tags {
  id uuid [primary key]
  name varchar(50) [unique, not null]
}

// ============================================================
// 填寫檢查清單
// ============================================================
// - [ ] 所有聚合根都有對應的表
// - [ ] 主鍵都使用 uuid
// - [ ] 必要欄位都加上 not null
// - [ ] 唯一性限制都已設定
// - [ ] 外鍵關係都已定義
// - [ ] 索引都已建立 (尤其是查詢常用欄位)
// - [ ] 時間戳記欄位 (created_at, updated_at) 都已加入
// - [ ] 業務規則都有 Note 說明
// - [ ] Enum 類型都有定義
// ============================================================

// ============================================================
// 最佳實踐
// ============================================================
// 1. 命名慣例:
//    - 表名: 複數小寫,底線分隔 (如: product_variants)
//    - 欄位: 小寫,底線分隔 (如: created_at)
//    - 索引: idx_表名_欄位名 (如: idx_users_email)
//
// 2. 主鍵:
//    - 使用 uuid 而非 auto-increment integer (更安全,支援分散式)
//
// 3. 時間戳記:
//    - 所有表都應有 created_at
//    - 常更新的表應有 updated_at
//
// 4. 軟刪除:
//    - 考慮使用 deleted_at 而非直接刪除資料
//
// 5. 索引策略:
//    - 外鍵欄位建立索引
//    - 常用於 WHERE 條件的欄位建立索引
//    - 常用於排序的欄位建立索引
//    - 避免過度索引 (影響寫入效能)
//
// 6. 正規化:
//    - 遵循第三正規化 (3NF)
//    - 但可適度反正規化以提升查詢效能
// ============================================================
