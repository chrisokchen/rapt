// 決策 CLR-260613-03#ASM#004（REJECTED）：支援一店多操作帳號 → 見 MerchantOperator；Merchant 為店家主體
Table Merchant {
  merchantId  nvarchar(60)   [pk, label: '商家編號', group: 'basic']
  email       nvarchar(100)  [not null, unique, sensitive: true, label: '登入信箱', group: 'account']
  password    nvarchar(150)  [not null, sensitive: true, label: '密碼', group: 'account']
  name        nvarchar(100)  [not null, label: '商家名稱', group: 'basic']
  phone       nvarchar(20)   [sensitive: true, label: '聯絡電話', group: 'contact']
  status      nchar(1)       [not null, default: 'P', ref_code: 'MerchantStatus', label: '帳號狀態', group: 'system']
  createdAt   datetime2(0)   [not null, label: '註冊時間', group: 'system']
  activatedAt datetime2(0)   [label: '開通時間', group: 'system']

  Note: 'MER001 商家主體（月租店家；登入操作者見 MerchantOperator，本表 email/password 為 owner 引導帳號）'
}

// 決策 CLR-260613-03#ASM#004：一店多操作帳號（店主＋店員子帳號）
Table MerchantOperator {
  operatorId nvarchar(60)  [pk, label: '操作者編號', group: 'basic']
  merchantId nvarchar(60)  [not null, label: '所屬商家', group: 'basic']
  email      nvarchar(100) [not null, unique, sensitive: true, label: '登入信箱', group: 'account']
  password   nvarchar(150) [not null, sensitive: true, label: '密碼', group: 'account']
  name       nvarchar(100) [not null, label: '操作者姓名', group: 'basic']
  isOwner    bit           [not null, default: 0, label: '是否店主', group: 'system']
  status     nchar(1)      [not null, default: 'A', ref_code: 'OperatorStatus', label: '帳號狀態', group: 'system']
  createdAt  datetime2(0)  [not null, label: '建立時間', group: 'system']

  Note: 'MER002 商家操作帳號（隸屬單一 Merchant CON-MOP-001；店面隔離以 operator→merchant→store 推導）'
}

Table Store {
  storeId    nvarchar(60)   [pk, label: '店面編號', group: 'basic']
  merchantId nvarchar(60)   [not null, unique, label: '所屬商家', group: 'basic']
  storeName  nvarchar(100)  [not null, label: '店面名稱', group: 'basic']
  status     nchar(1)       [not null, default: 'P', ref_code: 'StoreStatus', label: '營運狀態', group: 'system']
  createdAt  datetime2(0)   [not null, label: '建立時間', group: 'system']

  Note: 'STO001 店面主檔（MVP 一商家一店面；狀態與商家帳號同步 CON-MER-003）'
}

// 決策 CLR-260613-03#ASM#003（確認）：平台拆 admin/marketer；CLR-260613-02#Q1：MVP 後台僅開通/停權+商家清單
Table PlatformUser {
  platformUserId nvarchar(60)  [pk, label: '平台人員編號', group: 'basic']
  email          nvarchar(100) [not null, unique, sensitive: true, label: '登入信箱', group: 'account']
  password       nvarchar(150) [not null, sensitive: true, label: '密碼', group: 'account']
  name           nvarchar(100) [not null, label: '姓名', group: 'basic']
  roleCode       nvarchar(20)  [not null, ref_code: 'PlatformRole', label: '平台角色', group: 'system']
  isActive       bit           [not null, default: 1, label: '是否啟用', group: 'system']

  Note: 'PLT001 平台人員帳號（admin/marketer 角色拆分 ASM #003 未決；功能範圍 GAP #005）'
}

