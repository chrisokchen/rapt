  password     nvarchar(150) [not null, sensitive: true, label: '密碼', group: 'account']
  name         nvarchar(100) [not null, label: '會員姓名', group: 'basic']
  phone        nvarchar(20)  [sensitive: true, label: '手機號碼', group: 'contact']
  status       nchar(1)      [not null, default: 'V', ref_code: 'MemberStatus', label: '會員狀態', group: 'system']
  tierCode     nvarchar(20)  [not null, default: 'T1', ref_code: 'MemberTier', label: '會員等級', group: 'loyalty']
  pointBalance int           [not null, default: 0, label: '點數餘額', group: 'loyalty']
  createdAt    datetime2(0)  [not null, label: '註冊時間', group: 'system']
  verifiedAt   datetime2(0)  [label: '驗證時間', group: 'system']

  Note: 'MBR001 會員主檔（Email 唯一 CON-MBR-001；驗證後生效 CON-MBR-002；點數餘額反正規化 COMPAT-03；分級規則 GAP #010）'
}

Table MemberAddress {
  addressId     nvarchar(60)  [pk, label: '地址編號', group: 'basic']
