  productId  nvarchar(60) [not null, label: '收藏商品', group: 'basic']
  createdAt  datetime2(0) [not null, label: '加入時間', group: 'system']

  Note: 'MBR004 願望清單（會員收藏商品；降價時透過 NotificationLog 通知 CON-WSH-001）'
}

// =====================================================================
// Promotion（促銷）
// =====================================================================

Table Campaign {
  campaignId     nvarchar(60)  [pk, label: '活動編號', group: 'basic']
  storeId        nvarchar(60)  [not null, label: '所屬店面', group: 'basic']
  name           nvarchar(100) [not null, label: '活動名稱', group: 'basic']
  campaignType   nchar(1)      [not null, ref_code: 'CampaignType', label: '活動類型', group: 'rule']
  discountValue  decimal(18,2) [label: '折扣值（比例或金額）', group: 'rule']
  thresholdAmount decimal(18,2) [label: '滿額門檻', group: 'rule']
  buyQuantity    int           [label: '購買數量（買X）', group: 'rule']
  giftVariantId  nvarchar(60)  [label: '贈送 SKU（送Y）', group: 'rule']
  giftQuantity   int           [label: '贈送數量', group: 'rule']
  startAt        datetime2(0)  [not null, label: '檔期開始', group: 'schedule']
  endAt          datetime2(0)  [not null, label: '檔期結束', group: 'schedule']
  status         nchar(1)      [not null, default: 'S', ref_code: 'CampaignStatus', label: '活動狀態', group: 'system']
  createdAt      datetime2(0)  [not null, label: '建立時間', group: 'system']

  Note: 'PRM001 促銷活動（檔期自動生效/失效 CON-CMP-001；疊加順序 GAP #007）'
}

Table Coupon {
  couponId      nvarchar(60)  [pk, label: '優惠券編號', group: 'basic']
  storeId       nvarchar(60)  [not null, label: '所屬店面', group: 'basic']
  code          nvarchar(20)  [not null, unique, label: '券代碼', group: 'basic']
  name          nvarchar(100) [not null, label: '券名稱', group: 'basic']
  discountType  nchar(1)      [not null, ref_code: 'CouponDiscountType', label: '折扣方式', group: 'rule']
  discountValue decimal(18,2) [not null, label: '折扣值', group: 'rule']
  minSpend      decimal(18,2) [not null, default: 0, label: '最低消費門檻', group: 'rule']
  usageCap      int           [not null, label: '總使用張數上限', group: 'rule']
  usedCount     int           [not null, default: 0, label: '已使用張數', group: 'rule']
  validFrom     datetime2(0)  [not null, label: '有效期間起', group: 'schedule']
  validTo       datetime2(0)  [not null, label: '有效期間迄', group: 'schedule']
  tierLimit     nvarchar(20)  [ref_code: 'MemberTier', label: '限定會員等級', group: 'rule']
  createdAt     datetime2(0)  [not null, label: '建立時間', group: 'system']

  Note: 'PRM002 優惠券（門檻 CON-CPN-001；張數上限與已用數反正規化 COMPAT-04 / CON-CPN-002；等級限定 CON-CPN-003）'
}

Table CouponRedemption {
  redemptionId nvarchar(60) [pk, label: '使用紀錄編號', group: 'basic']
  couponId     nvarchar(60) [not null, label: '優惠券', group: 'basic']
  orderId      nvarchar(20) [not null, unique, label: '套用訂單', group: 'basic']
  memberId     nvarchar(60) [not null, label: '使用會員', group: 'basic']
  redeemedAt   datetime2(0) [not null, label: '使用時間', group: 'system']

  Note: 'PRM003 優惠券使用紀錄（orderId unique 落實一單一券 CON-ORD-004）'
}

// =====================================================================
// Notification（通知）
// =====================================================================

Table NotificationLog {
  notificationId nvarchar(60)  [pk, label: '通知編號', group: 'basic']
  memberId       nvarchar(60)  [not null, label: '收件會員', group: 'basic']
  orderId        nvarchar(20)  [label: '關聯訂單', group: 'basic']
  channel        nchar(1)      [not null, ref_code: 'NotificationChannel', label: '通知通道', group: 'basic']
  title          nvarchar(100) [not null, label: '通知標題', group: 'basic']
  content        nvarchar(500) [label: '通知內容', group: 'basic']
  sentAt         datetime2(0)  [not null, label: '發送時間', group: 'system']

  Note: 'NTF001 通知發送紀錄（LINE / Email 推播）'
}

// =====================================================================
// Audit（稽核）
// =====================================================================

// 決策 CLR-260613-02#GAP#013：通用稽核軌跡，涵蓋訂單狀態/退款/停權/價格庫存（CON-AUD-001）
Table AuditLog {
  auditId      nvarchar(60)  [pk, label: '稽核編號', group: 'basic']
  actorType    nchar(1)      [not null, ref_code: 'AuditActorType', label: '操作者類型', group: 'basic']
  actorId      nvarchar(60)  [not null, label: '操作者編號', group: 'basic']
  action       nchar(2)      [not null, ref_code: 'AuditAction', label: '操作類型', group: 'basic']
  targetEntity nvarchar(60)  [not null, label: '目標實體', group: 'basic']
  targetId     nvarchar(60)  [not null, label: '目標編號', group: 'basic']
  beforeValue  nvarchar(500) [label: '異動前值', group: 'detail']
  afterValue   nvarchar(500) [label: '異動後值', group: 'detail']
  createdAt    datetime2(0)  [not null, label: '操作時間', group: 'system']

  Note: 'AUD001 稽核紀錄（訂單狀態變更/退款/商家停權/價格庫存異動 CON-AUD-001）'
}

// =====================================================================
// Refs（外鍵宣告；- 為 1:1，> 為 many-to-one）
// =====================================================================

Ref: MerchantOperator.merchantId > Merchant.merchantId
Ref: Store.merchantId - Merchant.merchantId
Ref: Category.storeId > Store.storeId
Ref: Category.parentCategoryId > Category.categoryId
Ref: Brand.storeId > Store.storeId
Ref: Product.storeId > Store.storeId
Ref: Product.categoryId > Category.categoryId
Ref: Product.brandId > Brand.brandId
Ref: ProductImage.productId > Product.productId
Ref: ProductVariant.productId > Product.productId
Ref: StockItem.variantId - ProductVariant.variantId
Ref: Cart.memberId - Member.memberId
Ref: CartItem.cartId > Cart.cartId
Ref: CartItem.variantId > ProductVariant.variantId
Ref: Order.storeId > Store.storeId
Ref: Order.memberId > Member.memberId
Ref: Order.couponId > Coupon.couponId
Ref: OrderItem.orderId > Order.orderId
Ref: OrderItem.variantId > ProductVariant.variantId
Ref: Payment.orderId > Order.orderId
Ref: Invoice.orderId > Order.orderId
Ref: Refund.orderId > Order.orderId
Ref: Refund.paymentId > Payment.paymentId
Ref: Shipment.orderId - Order.orderId
Ref: ReturnRequest.orderId > Order.orderId
Ref: ReturnRequest.memberId > Member.memberId
Ref: MemberAddress.memberId > Member.memberId
Ref: PointLedger.memberId > Member.memberId
Ref: PointLedger.orderId > Order.orderId
Ref: Campaign.storeId > Store.storeId
Ref: Campaign.giftVariantId > ProductVariant.variantId
Ref: Coupon.storeId > Store.storeId
Ref: CouponRedemption.couponId > Coupon.couponId
Ref: CouponRedemption.orderId - Order.orderId
Ref: CouponRedemption.memberId > Member.memberId
Ref: NotificationLog.memberId > Member.memberId
Ref: NotificationLog.orderId > Order.orderId
Ref: Wishlist.memberId > Member.memberId
Ref: Wishlist.productId > Product.productId
