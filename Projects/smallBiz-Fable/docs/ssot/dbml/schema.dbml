  orderId      nvarchar(20) [label: '關聯訂單', group: 'basic']
  changeType   nchar(1)     [not null, ref_code: 'PointChangeType', label: '異動類型', group: 'basic']
  points       int          [not null, label: '異動點數（正負）', group: 'basic']
  balanceAfter int          [not null, label: '異動後餘額', group: 'basic']
  expireAt     datetime2(0) [label: '點數效期（獲得型適用）', group: 'basic']
