  amount           decimal(18,2) [not null, label: '付款金額', group: 'basic']
  gatewayTradeNo   nvarchar(60)  [label: '金流交易序號', group: 'basic']
  transferLastFive nchar(5)      [sensitive: true, label: '匯款帳號後五碼', group: 'basic']
