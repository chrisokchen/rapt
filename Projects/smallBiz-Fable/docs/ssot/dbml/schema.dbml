  Note: 'ORD001 訂單主檔（七種狀態 CON-ORD-001；金額計算順序 GAP #007 / CON-ORD-008；一單一券 CON-ORD-004）'
}

Table OrderItem {
  orderItemId nvarchar(60)  [pk, label: '明細編號', group: 'basic']
