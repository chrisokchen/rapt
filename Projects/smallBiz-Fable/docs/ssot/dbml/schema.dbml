  Note: 'PAY001 付款紀錄（支付資訊不落地，僅存金流交易序號；轉帳後五碼對帳 CON-PAY-001）'
}

Table Invoice {
  invoiceId   nvarchar(60)  [pk, label: '發票編號（系統）', group: 'basic']
  orderId     nvarchar(20)  [not null, label: '所屬訂單', group: 'basic']
  invoiceNo   nvarchar(20)  [not null, unique, label: '發票號碼', group: 'basic']
  taxAmount   decimal(18,2) [not null, label: '營業稅額', group: 'basic']
  totalAmount decimal(18,2) [not null, label: '發票金額', group: 'basic']
  issuedAt    datetime2(0)  [not null, label: '開立時間', group: 'system']

  Note: 'PAY002 電子發票（einvoice-service 開立；5% 營業稅，稅基口徑 GAP #007 / CON-ORD-006）'
}

// 決策 CLR-260613-01#Q3：退款一律原路退回（不需額外路徑欄位）
Table Refund {
  refundId   nvarchar(60)  [pk, label: '退款編號', group: 'basic']
