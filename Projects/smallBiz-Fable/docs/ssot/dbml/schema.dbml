  Note: 'MBR003 點數異動帳（折抵≤餘額 CON-PNT-001；餘額補償核對 CON-PNT-002；效期1年 CON-PNT-005；折抵上限50% CON-PNT-003；回饋折後實付 CON-PNT-004）'
}

// 決策 CLR-260613-03#GAP#002：願望清單入 MVP；降價時通知（CON-WSH-001）
Table Wishlist {
  wishlistId nvarchar(60) [pk, label: '願望清單編號', group: 'basic']
