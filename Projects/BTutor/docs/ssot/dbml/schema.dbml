// =====================================================================
// === Identity Context（使用者）===
// =====================================================================

Table UserAccount {
  userId       nvarchar(60)  [pk, label: '使用者帳號', group: 'basic']
  displayName  nvarchar(100) [not null, label: '顯示名稱', group: 'basic']
  userType     nchar(1)      [not null, ref_code: 'UserType', label: '使用者類型', group: 'basic']
  email        nvarchar(150) [not null, sensitive: true, label: '電子郵件', group: 'contact']
  passwordHash nvarchar(150) [not null, sensitive: true, label: '密碼雜湊', group: 'system']
  enabled      bit           [not null, default: 1, label: '是否啟用', group: 'system']
  createdAt    datetime2(0)  [not null, label: '建立時間', group: 'system']

  Note: 'USR001 使用者帳號主檔（學生 / 教練 / 標注者 / 研究者）'
}

Table StudentProfile {
  studentId      nvarchar(60) [pk, label: '學生帳號', group: 'basic']
  cognitiveLevel nchar(1)     [not null, ref_code: 'CognitiveLevel', label: '認知層級', group: 'basic']
  enrolledAt     datetime2(0) [not null, label: '建檔時間', group: 'system']

  Note: 'STU001 學生認知檔案（涵蓋中級卡關玩家與青少年學習者）'
}

Table CoachStudentLink {
  linkId    nvarchar(60) [pk, label: '關係編號', group: 'basic']
  coachId   nvarchar(60) [not null, label: '教練', group: 'basic']
  studentId nvarchar(60) [not null, label: '學生', group: 'basic']
  linkedAt  datetime2(0) [not null, label: '建立時間', group: 'system']

  Note: 'CSL001 教練與學生的指導關係'
}

Table GuardianStudentLink {
  linkId     nvarchar(60) [pk, label: '關係編號', group: 'basic']
  guardianId nvarchar(60) [not null, label: '家長 / 監護人', group: 'basic']
  studentId  nvarchar(60) [not null, label: '學生', group: 'basic']
  linkedAt   datetime2(0) [not null, label: '建立時間', group: 'system']

  Note: 'GSL001 家長 / 學校與學習者的監護關係（CLR-260616-01#Q8）'
}

// =====================================================================
