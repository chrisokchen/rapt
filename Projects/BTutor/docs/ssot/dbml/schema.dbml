Table PlaySession {
  sessionId  nvarchar(60) [pk, label: '練習編號', group: 'basic']
  studentId  nvarchar(60) [not null, label: '學生', group: 'basic']
  dealId     nvarchar(60) [not null, label: '牌例', group: 'basic']
  status     nchar(1)     [not null, default: 'I', ref_code: 'SessionStatus', label: '練習狀態', group: 'basic']
  startedAt  datetime2(0) [not null, label: '開始時間', group: 'system']
  completedAt datetime2(0) [label: '完成時間', group: 'system']

  Note: 'SESS001 一副牌例的練習 session（event sourcing 的聚合根）'
}

Table ActionTrace {
  actionId    nvarchar(60)  [pk, label: '出牌編號', group: 'basic']
  sessionId   nvarchar(60)  [not null, label: '練習', group: 'basic']
  trickNo     int           [not null, label: '墩次', group: 'play']
  seat        nchar(1)      [not null, ref_code: 'Seat', label: '出牌方位', group: 'play']
  selectedCard nvarchar(4)  [not null, label: '所選牌', group: 'play']
  legalCards  nvarchar(max) [not null, label: '當時合法牌（JSON）', group: 'play']
  thinkTimeMs int           [not null, default: 0, label: '思考時間（毫秒）', group: 'telemetry']
  undoCount   int           [not null, default: 0, label: '悔牌次數', group: 'telemetry']
  recordedAt  datetime2(0)  [not null, label: '記錄時間', group: 'system']

  Note: 'ACT001 逐墩出牌認知軌跡（selected_card / legal_cards / think_time / undo）'
}

Table HintEvent {
  hintId     nvarchar(60) [pk, label: '提示編號', group: 'basic']
  sessionId  nvarchar(60) [not null, label: '練習', group: 'basic']
  trickNo    int          [not null, label: '墩次', group: 'play']
  hintLevel  nchar(1)     [not null, ref_code: 'HintLevel', label: '提示層級', group: 'play']
  requestedAt datetime2(0) [not null, label: '請求時間', group: 'system']

  Note: 'HINT001 漸進式提示事件（hint escalation 本身即認知訊號）'
}

Table ReasoningTag {
  reasoningId nvarchar(60) [pk, label: '推理標記編號', group: 'basic']
  sessionId   nvarchar(60) [not null, label: '練習', group: 'basic']
  trickNo     int          [not null, label: '墩次', group: 'play']
  tagCode     nchar(2)     [not null, ref_code: 'ReasoningTag', label: '推理標籤', group: 'play']
  triggerType nchar(1)     [not null, ref_code: 'ReasoningTrigger', label: '觸發類型', group: 'play']
  taggedAt    datetime2(0) [not null, label: '標記時間', group: 'system']

  Note: 'REASON001 觸發式推理標記（長考 / 關鍵錯誤 / 高階提示時蒐集）'
}

// =====================================================================
// === Diagnosis Context（診斷）===
// =====================================================================

Table Diagnosis {
  diagnosisId    nvarchar(60)  [pk, label: '診斷編號', group: 'basic']
  sessionId      nvarchar(60)  [not null, label: '練習', group: 'basic']
  targetSkillId  nvarchar(60)  [not null, label: '對應技能', group: 'basic']
  ruleSetVersion nvarchar(20)  [not null, label: '依據規則集版本', group: 'basic']
  hypothesis     nvarchar(200) [not null, label: '診斷假設', group: 'diagnosis']
  confidence     decimal(4,3)  [not null, label: '信心值', group: 'diagnosis']
  mistakeCategory nchar(2)     [ref_code: 'MistakeCategory', label: '錯誤分類', group: 'diagnosis']
  severity       nchar(1)      [ref_code: 'MistakeSeverity', label: '嚴重度', group: 'diagnosis']
  cognitiveOrigin nchar(1)     [ref_code: 'CognitiveOrigin', label: '認知成因', group: 'diagnosis']
  recoverability nchar(1)      [ref_code: 'Recoverability', label: '可回復性', group: 'diagnosis']
  isStylistic    bit           [not null, default: 0, label: '是否為風格差異', group: 'diagnosis']
  diagnosedAt    datetime2(0)  [not null, label: '診斷時間', group: 'system']

  Note: 'DIAG001 認知診斷假設（rule + probabilistic 產生，非 binary 正解）'
}

Table DiagnosisEvidence {
  evidenceId    nvarchar(60)  [pk, label: '證據編號', group: 'basic']
  diagnosisId   nvarchar(60)  [not null, label: '診斷', group: 'basic']
  ruleId        nvarchar(60)  [label: '引用規則', group: 'evidence']
  evidenceText  nvarchar(500) [not null, label: '證據描述', group: 'evidence']
  sourceActionId nvarchar(60) [label: '來源出牌', group: 'evidence']
  masteryDelta  decimal(5,4)  [label: '學生模型變化量', group: 'evidence']

  Note: 'EVID001 可審計證據日誌明細（支撐每筆 diagnosis 的回溯依據）'
}

Table CoachingFeedback {
  feedbackId       nvarchar(60)  [pk, label: '教學編號', group: 'basic']
  diagnosisId      nvarchar(60)  [not null, label: '診斷', group: 'basic']
  explanationText  nvarchar(max) [not null, label: '賽後教學說明', group: 'coaching']
  suggestedSkillId nvarchar(60)  [label: '建議訓練技能', group: 'coaching']
  generatedAt      datetime2(0)  [not null, label: '產生時間', group: 'system']

  Note: 'FEEDBACK001 賽後教學（LLM 依層級調整語氣，只 narration 不判案）'
}

Table CoachReview {
  reviewId    nvarchar(60)  [pk, label: '覆核編號', group: 'basic']
  diagnosisId nvarchar(60)  [not null, label: '診斷', group: 'basic']
  coachId     nvarchar(60)  [not null, label: '教練', group: 'basic']
  agreement   nchar(1)      [not null, ref_code: 'ReviewAgreement', label: '是否同意', group: 'review']
  comment     nvarchar(500) [label: '覆核意見', group: 'review']
  reviewedAt  datetime2(0)  [not null, label: '覆核時間', group: 'system']

  Note: 'REVIEW001 教練對 AI 診斷的覆核與分歧標記（高價值 dataset）'
}

// =====================================================================
// === Student Model Context（學生模型）===
// =====================================================================

Table StudentSkillState {
  stateId           nvarchar(60) [pk, label: '狀態編號', group: 'basic']
  studentId         nvarchar(60) [not null, label: '學生', group: 'basic']
  skillId           nvarchar(60) [not null, label: '技能', group: 'basic']
  recognitionMastery decimal(4,3) [not null, default: 0, label: '辨識精熟度', group: 'mastery']
  executionMastery  decimal(4,3) [not null, default: 0, label: '執行精熟度', group: 'mastery']
  transferMastery   decimal(4,3) [not null, default: 0, label: '遷移精熟度', group: 'mastery']
  retentionMastery  decimal(4,3) [not null, default: 0, label: '保留精熟度', group: 'mastery']
  confidence        decimal(4,3) [not null, default: 0, label: '估計信心', group: 'mastery']
  trend             nchar(1)     [not null, default: 'S', ref_code: 'MasteryTrend', label: '趨勢', group: 'mastery']
  updatedAt         datetime2(0) [not null, label: '更新時間', group: 'system']

  Note: 'SKILLSTATE001 多維 partial mastery（辨識 / 執行 / 遷移 / 保留，probabilistic）'
}

// =====================================================================
// === Replay & Governance Context（重播與治理）===
// =====================================================================

Table Assignment {
  assignmentId nvarchar(60) [pk, label: '指派編號', group: 'basic']
  coachId      nvarchar(60) [not null, label: '指派教練', group: 'basic']
  studentId    nvarchar(60) [not null, label: '學生', group: 'basic']
  dealId       nvarchar(60) [not null, label: '指派牌例', group: 'basic']
  targetSkillId nvarchar(60) [label: '目標認知缺口技能', group: 'basic']
  status       nchar(1)     [not null, default: 'A', ref_code: 'AssignmentStatus', label: '指派狀態', group: 'basic']
  assignedAt   datetime2(0) [not null, label: '指派時間', group: 'system']

  Note: 'ASSIGN001 教練派發的針對性訓練'
}

Table LearningEvent {
  eventId         nvarchar(60)  [pk, label: '事件編號', group: 'basic']
  sessionId       nvarchar(60)  [not null, label: '練習', group: 'basic']
  studentId       nvarchar(60)  [not null, label: '學生', group: 'basic']
  eventType       nchar(1)      [not null, ref_code: 'LearningEventType', label: '事件類型', group: 'event']
  sequenceNo      int           [not null, label: '序號', group: 'event']
  payload         nvarchar(max) [not null, label: '事件內容（JSON）', group: 'event']
  ontologyVersion nvarchar(20)  [not null, label: '當時本體版本', group: 'event']
  ruleSetVersion  nvarchar(20)  [not null, label: '當時規則集版本', group: 'event']
  occurredAt      datetime2(0)  [not null, label: '發生時間', group: 'system']

  Note: 'EVENT001 event-sourced 學習事件流（append-only，state = replay(events)）'
}

Table ReplayRun {
  replayId        nvarchar(60) [pk, label: '重播編號', group: 'basic']
  scope           nchar(1)     [not null, ref_code: 'ReplayScope', label: '重播範圍', group: 'basic']
  scopeRefId      nvarchar(60) [not null, label: '重播對象（session / student）', group: 'basic']
  replayType      nchar(1)     [not null, ref_code: 'ReplayType', label: '重播用途', group: 'basic']
  ontologyVersion nvarchar(20) [not null, label: '套用本體版本', group: 'replay']
  ruleSetVersion  nvarchar(20) [not null, label: '套用規則集版本', group: 'replay']
  triggeredBy     nvarchar(60) [not null, label: '執行者', group: 'system']
  ranAt           datetime2(0) [not null, label: '執行時間', group: 'system']

  Note: 'REPLAY001 可重現重播（Debug / Research / Student-History，指定 ontology+rule 版本）'
}

