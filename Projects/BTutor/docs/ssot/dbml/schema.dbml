// =====================================================================
// === Bounded Context Groups ===
// =====================================================================

TableGroup IdentityContext {
  UserAccount
  StudentProfile
  CoachStudentLink
  GuardianStudentLink
}

TableGroup AuthoringContext {
  CuratedDeal
  SituationAnnotation
  OntologyVersion
  CognitiveSkill
  RuleSet
  DiagnosisRule
  OntologyProposal
}

TableGroup PlayTelemetryContext {
  PlaySession
  ActionTrace
  HintEvent
  ReasoningTag
}

TableGroup DiagnosisContext {
  Diagnosis
  DiagnosisEvidence
  CoachingFeedback
  CoachReview
}

TableGroup StudentModelContext {
  StudentSkillState
}

TableGroup ReplayGovernanceContext {
  Assignment
  LearningEvent
  ReplayRun
}
