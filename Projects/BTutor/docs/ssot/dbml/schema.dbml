Table CuratedDeal {
  dealId         nvarchar(60)   [pk, label: '牌例編號', group: 'basic']
  title          nvarchar(100)  [not null, label: '牌例標題', group: 'basic']
  handsPbn       nvarchar(max)  [not null, label: '四家牌（PBN）', group: 'deal']
  contract       nvarchar(20)   [not null, label: '合約', group: 'deal']
  declarer       nchar(1)       [not null, ref_code: 'Seat', label: '莊家方位', group: 'deal']
  scoringContext nchar(1)       [not null, default: 'I', ref_code: 'ScoringContext', label: '計分制', group: 'deal']
  authorId       nvarchar(60)   [not null, label: '建立標注者', group: 'system']
  createdAt      datetime2(0)   [not null, label: '建立時間', group: 'system']

  Note: 'DEAL001 人工 curated 的橋引管理牌例'
}

Table SituationAnnotation {
  annotationId    nvarchar(60)  [pk, label: '標注編號', group: 'basic']
  dealId          nvarchar(60)  [not null, label: '牌例', group: 'basic']
  situationType   nchar(2)      [not null, ref_code: 'SituationType', label: '局面類型', group: 'basic']
  ontologyVersion nvarchar(20)  [not null, label: '依據本體版本', group: 'basic']
  dslBody         nvarchar(max) [not null, label: 'Situation DSL 內文', group: 'annotation']
  isComplete      bit           [not null, default: 0, label: '是否標注完整', group: 'annotation']
  updatedAt       datetime2(0)  [not null, label: '更新時間', group: 'system']

  Note: 'ANNO001 牌例的 Situation DSL 標注（critical_moments / skills / acceptable_lines / common_mistakes）'
}

Table OntologyVersion {
  ontologyVersion nvarchar(20)  [pk, label: '本體版本', group: 'basic']
  title           nvarchar(100) [not null, label: '版本標題', group: 'basic']
  status          nchar(1)      [not null, default: 'D', ref_code: 'PublishStatus', label: '版本狀態', group: 'basic']
  publishedAt     datetime2(0)  [label: '發布時間', group: 'system']
  publishedBy     nvarchar(60)  [label: '發布者', group: 'system']

  Note: 'ONT001 版本化的認知本體（versioned，可重播比較）'
}

Table CognitiveSkill {
  skillId         nvarchar(60)  [pk, label: '技能編號', group: 'basic']
  ontologyVersion nvarchar(20)  [not null, label: '所屬本體版本', group: 'basic']
  skillCode       nvarchar(60)  [not null, label: '技能代碼', group: 'basic']
  skillName       nvarchar(100) [not null, label: '技能名稱', group: 'basic']
  cognitiveLevel  nchar(1)      [not null, ref_code: 'CognitiveLevel', label: '認知層級', group: 'basic']
  parentSkillId   nvarchar(60)  [label: '上層技能', group: 'graph']

  Note: 'SKILL001 認知技能（橋引辨識 / 保留 / 排序 / unblock 等），構成 skill graph'
}

Table RuleSet {
  ruleSetVersion nvarchar(20)  [pk, label: '規則集版本', group: 'basic']
  title          nvarchar(100) [not null, label: '規則集標題', group: 'basic']
  status         nchar(1)      [not null, default: 'D', ref_code: 'PublishStatus', label: '版本狀態', group: 'basic']
  publishedAt    datetime2(0)  [label: '發布時間', group: 'system']

  Note: 'RULESET001 版本化的診斷規則集'
}

Table DiagnosisRule {
  ruleId         nvarchar(60)  [pk, label: '規則編號', group: 'basic']
  ruleSetVersion nvarchar(20)  [not null, label: '所屬規則集版本', group: 'basic']
  targetSkillId  nvarchar(60)  [not null, label: '對應技能', group: 'basic']
  mistakeCategory nchar(2)     [not null, ref_code: 'MistakeCategory', label: '錯誤分類', group: 'basic']
  conditionExpr  nvarchar(max) [not null, label: '判定條件', group: 'rule']
  description    nvarchar(500) [not null, label: '規則說明', group: 'rule']

  Note: 'RULE001 診斷規則（evidence mapping / rule conditions / mistake taxonomy）'
}

Table OntologyProposal {
  proposalId     nvarchar(60)  [pk, label: '提案編號', group: 'basic']
  baseVersion    nvarchar(20)  [not null, label: '基準本體版本', group: 'basic']
  status         nchar(1)      [not null, default: 'P', ref_code: 'ProposalStatus', label: '提案狀態', group: 'basic']
  rationale      nvarchar(max) [not null, label: '提案理由（含共現證據）', group: 'proposal']
  proposedAt     datetime2(0)  [not null, label: '提出時間', group: 'system']
  reviewedBy     nvarchar(60)  [label: '核可者', group: 'governance']
  reviewedAt     datetime2(0)  [label: '核可時間', group: 'governance']

  Note: 'PROP001 本體演化提案（AI suggests, human governs）'
}

